<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.samizdat.proxy</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/samizdat-proxy</string>
        <string>--config</string>
        <string>/etc/samizdat/proxy.toml</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/log/samizdat-proxy-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/samizdat-proxy-stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>RUST_BACKTRACE</key>
        <string>1</string>
    </dict>
</dict>
</plist>
